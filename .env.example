# ─────────────────────────────────────────────────────────────
# Dar Tahara — environment variables
# Copy to .env.local and fill in. .env*.local is gitignored.
# ─────────────────────────────────────────────────────────────

# Supabase (REQUIRED for the mailing-list form to store submissions)
# URL + publishable key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy fallback (optional). Use only when the project still uses JWT-based
# anon keys and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is unset.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key (OPTIONAL) — server-only, NEVER expose to the client.
# Enables: admin export (/api/admin/subscribers) and double opt-in email
# token lookup. Get it from Supabase dashboard → Settings → API.
SUPABASE_SECRET_KEY=

# Legacy fallback (optional). Use only when the project still uses the
# JWT-based service-role key and SUPABASE_SECRET_KEY is unset.
SUPABASE_SERVICE_ROLE_KEY=

# Admin export bearer token (OPTIONAL). Required to call /api/admin/subscribers.
# Generate a long random string, e.g. `openssl rand -hex 32`.
ADMIN_API_TOKEN=

# Cloudflare Turnstile bot protection (OPTIONAL). When unset, verification is
# skipped and the form still works. https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Double opt-in confirmation email via Resend (OPTIONAL). When unset,
# subscribers are stored as unconfirmed and no email is sent.
RESEND_API_KEY=
MAILING_FROM_EMAIL=Dar Tahara <hello@dartahara.com>
